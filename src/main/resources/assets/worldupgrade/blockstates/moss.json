{
  "multipart": [
    {   "when": { "down": "true" },
      "apply": { "model": "worldupgrade:block/moss_down", "uvlock": true }
    },
    {   "when": { "up": "true" },
      "apply": { "model": "worldupgrade:block/moss_up", "uvlock": true }
    },
    {   "when": { "north": "true",  "below": "true"},
      "apply": { "model": "worldupgrade:block/moss_side", "uvlock": true }
    },
    {   "when": { "east": "true",  "below": "true" },
      "apply": { "model": "worldupgrade:block/moss_side", "y": 90, "uvlock": true }
    },
    {   "when": { "south": "true",  "below": "true" },
      "apply": { "model": "worldupgrade:block/moss_side", "y": 180, "uvlock": true }
    },
    {   "when": { "west": "true",  "below": "true" },
      "apply": { "model": "worldupgrade:block/moss_side", "y": 270, "uvlock": true }
    },
    {   "when": { "north": "true",  "below": "false"},
      "apply": { "model": "worldupgrade:block/moss_small_side", "uvlock": true }
    },
    {   "when": { "east": "true",  "below": "false" },
      "apply": { "model": "worldupgrade:block/moss_small_side", "y": 90, "uvlock": true }
    },
    {   "when": { "south": "true",  "below": "false" },
      "apply": { "model": "worldupgrade:block/moss_small_side", "y": 180, "uvlock": true }
    },
    {   "when": { "west": "true",  "below": "false" },
      "apply": { "model": "worldupgrade:block/moss_small_side", "y": 270, "uvlock": true }
    }
  ]
}